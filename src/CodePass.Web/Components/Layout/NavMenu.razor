@implements IDisposable
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CodePass</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (CurrentSolutionId is null)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/solutions">
                    <span class="bi bi-folder2-open" aria-hidden="true"></span> Solutions
                </NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@WorkspaceHref("dashboard")">
                    <span class="bi bi-speedometer2" aria-hidden="true"></span> Score
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@WorkspaceHref("analysis/rules")">
                    <span class="bi bi-search" aria-hidden="true"></span> Rule Analysis
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@WorkspaceHref("analysis/coverage")">
                    <span class="bi bi-bar-chart-line" aria-hidden="true"></span> Coverage Analysis
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@WorkspaceHref("settings")">
                    <span class="bi bi-gear" aria-hidden="true"></span> Settings
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private Guid? CurrentSolutionId => TryGetCurrentSolutionId();

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private string WorkspaceHref(string section)
        => CurrentSolutionId is Guid solutionId ? $"/solutions/{solutionId}/{section}" : "/solutions";

    private Guid? TryGetCurrentSolutionId()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Split('?', '#')[0];
        var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries);

        return segments.Length >= 2
            && segments[0].Equals("solutions", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(segments[1], out var solutionId)
                ? solutionId
                : null;
    }
}
