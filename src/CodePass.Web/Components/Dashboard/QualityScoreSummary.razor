@using CodePass.Web.Services.Dashboard

<section class="card shadow-sm border-0 h-100" aria-labelledby="quality-score-summary-heading" data-testid="quality-score-summary">
    <div class="card-body">
        <div class="d-flex flex-column flex-sm-row align-items-sm-start justify-content-between gap-3 mb-3">
            <div>
                <p class="text-body-secondary text-uppercase small fw-semibold mb-1">Quality score</p>
                <h2 class="h4 mb-0" id="quality-score-summary-heading">@DisplaySolutionName</h2>
            </div>

            @if (Snapshot is not null)
            {
                <span class="badge @GetStatusBadgeClass(Snapshot.Status)" data-testid="quality-status-badge">@GetStatusText(Snapshot.Status)</span>
            }
        </div>

        @if (Snapshot is null)
        {
            <div class="border rounded-3 p-4 text-center" data-testid="quality-score-empty-state">
                <h3 class="h5 mb-2">No current quality score</h3>
                <p class="text-body-secondary mb-0">Run rule analysis and coverage analysis before a current score is available.</p>
            </div>
        }
        else
        {
            <div class="d-flex align-items-baseline gap-2 mb-2" aria-label="Current quality score">
                <span class="display-3 fw-semibold lh-1" data-testid="quality-score-value">@FormatScore(Snapshot.Score)</span>
                <span class="h4 text-body-secondary mb-0">/100</span>
            </div>

            <p class="text-body-secondary mb-3">Latest rule and coverage evidence combine into this pass/fail score.</p>

            @if (Snapshot.BlockingReasons.Count > 0)
            {
                <div class="alert alert-warning mb-0" role="status" data-testid="quality-snapshot-reasons">
                    <p class="fw-semibold mb-2">Blocking reasons</p>
                    <ul class="mb-0 ps-3">
                        @foreach (var reason in Snapshot.BlockingReasons)
                        {
                            <li>@reason</li>
                        }
                    </ul>
                </div>
            }
        }
    </div>
</section>

@code {
    [Parameter]
    public QualityScoreSnapshotDto? Snapshot { get; set; }

    [Parameter]
    public string? SolutionName { get; set; }

    private string DisplaySolutionName
        => string.IsNullOrWhiteSpace(SolutionName) ? "Selected solution" : SolutionName;

    private static string FormatScore(double score)
        => score.ToString("0.#");

    private static string GetStatusText(QualityScoreStatus status)
        => status == QualityScoreStatus.Pass ? "Pass" : "Fail";

    private static string GetStatusBadgeClass(QualityScoreStatus status)
        => status == QualityScoreStatus.Pass ? "text-bg-success" : "text-bg-danger";
}
