@using System.ComponentModel.DataAnnotations
@using CodePass.Web.Data.Entities
@using CodePass.Web.Services.Solutions
@implements IDisposable
@inject ISolutionPathValidator SolutionPathValidator
@inject IRegisteredSolutionService RegisteredSolutionService

@if (IsOpen)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content shadow">
                <div class="modal-header">
                    <div>
                        <h2 class="modal-title h4 mb-1">Manage solution</h2>
                        <p class="text-body-secondary mb-0">Update the saved display name or <code>.sln</code> path, or remove this registration after confirmation.</p>
                    </div>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseAsync"></button>
                </div>

                <EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmitAsync">
                    <DataAnnotationsValidator />
                    <div class="modal-body d-flex flex-column gap-3">
                        @if (!string.IsNullOrWhiteSpace(SubmissionError))
                        {
                            <div class="alert alert-danger mb-0" role="alert" data-testid="edit-submission-error">@SubmissionError</div>
                        }

                        <div>
                            <label class="form-label" for="edit-display-name">Display name</label>
                            <InputText id="edit-display-name" class="form-control" @bind-Value="Model.DisplayName" data-testid="edit-display-name-input" />
                            <ValidationMessage For="() => Model.DisplayName" />
                        </div>

                        <div>
                            <label class="form-label" for="edit-solution-path">Solution path</label>
                            <InputText id="edit-solution-path" class="form-control" @bind-Value="Model.SolutionPath" data-testid="edit-solution-path-input" />
                            <div class="form-text">Changing the path requires CodePass to revalidate the new <code>.sln</code> path before the update can be saved.</div>
                            <ValidationMessage For="() => Model.SolutionPath" />
                        </div>

                        <div class="rounded border p-3 bg-body-tertiary" data-testid="delete-panel">
                            <div class="d-flex flex-column gap-2 flex-md-row align-items-md-center justify-content-between">
                                <div>
                                    <h3 class="h6 mb-1">Remove registration</h3>
                                    <p class="text-body-secondary mb-0">Deleting removes this saved solution from CodePass. This action is only available here.</p>
                                </div>

                                @if (!IsConfirmingDelete)
                                {
                                    <button class="btn btn-outline-danger" type="button" @onclick="BeginDeleteConfirmation" data-testid="show-delete-confirmation-button" disabled="@IsSubmitting">Remove</button>
                                }
                            </div>

                            @if (IsConfirmingDelete)
                            {
                                <div class="mt-3 border-top pt-3" data-testid="delete-confirmation">
                                    <p class="mb-3">Confirm removal of <strong>@OriginalDisplayName</strong> from the registered solutions list.</p>
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button class="btn btn-outline-secondary" type="button" @onclick="CancelDeleteConfirmation" disabled="@IsSubmitting">Cancel</button>
                                        <button class="btn btn-danger" type="button" @onclick="DeleteAsync" data-testid="confirm-delete-button" disabled="@IsSubmitting">@(IsSubmitting ? "Removing..." : "Confirm remove")</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" type="button" @onclick="CloseAsync" disabled="@IsSubmitting">Cancel</button>
                        <button class="btn btn-primary" type="submit" data-testid="save-edit-button" disabled="@IsSubmitting">@(IsSubmitting ? "Saving..." : "Save changes")</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@code {
    private readonly EditSolutionModel Model = new();
    private ValidationMessageStore? ValidationMessageStore { get; set; }
    private EditContext EditContext { get; set; } = default!;
    private string? SubmissionError { get; set; }
    private bool IsSubmitting { get; set; }
    private bool IsConfirmingDelete { get; set; }
    private Guid CurrentSolutionId { get; set; }
    private string OriginalDisplayName { get; set; } = string.Empty;
    private string OriginalSolutionPath { get; set; } = string.Empty;

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public RegisteredSolution? Solution { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnDeleted { get; set; }

    protected override void OnInitialized()
    {
        EditContext = new EditContext(Model);
        ValidationMessageStore = new ValidationMessageStore(EditContext);
        EditContext.OnFieldChanged += HandleFieldChanged;
    }

    protected override void OnParametersSet()
    {
        if (!IsOpen || Solution is null)
        {
            return;
        }

        LoadFromSolution(Solution);
        SubmissionError = null;
        ValidationMessageStore?.Clear();
        EditContext.NotifyValidationStateChanged();
        IsConfirmingDelete = false;
    }

    private async Task HandleValidSubmitAsync()
    {
        if (Solution is null)
        {
            return;
        }

        SubmissionError = null;
        ValidationMessageStore?.Clear();

        try
        {
            IsSubmitting = true;

            var solutionPath = Model.SolutionPath.Trim();
            if (!string.Equals(solutionPath, OriginalSolutionPath, StringComparison.Ordinal))
            {
                var validation = await SolutionPathValidator.ValidateAsync(solutionPath);
                if (!validation.IsValid)
                {
                    ValidationMessageStore?.Add(() => Model.SolutionPath, validation.Message ?? "The selected solution path is invalid.");
                    EditContext.NotifyValidationStateChanged();
                    return;
                }

                Model.SolutionPath = validation.CanonicalPath ?? solutionPath;
            }

            await RegisteredSolutionService.UpdateAsync(CurrentSolutionId, new UpdateRegisteredSolutionRequest(Model.DisplayName, Model.SolutionPath));
            Reset();
            await OnSaved.InvokeAsync();
        }
        catch (InvalidOperationException ex)
        {
            SubmissionError = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void BeginDeleteConfirmation()
    {
        IsConfirmingDelete = true;
        SubmissionError = null;
    }

    private void CancelDeleteConfirmation()
    {
        IsConfirmingDelete = false;
        SubmissionError = null;
    }

    private async Task DeleteAsync()
    {
        if (Solution is null)
        {
            return;
        }

        SubmissionError = null;

        try
        {
            IsSubmitting = true;
            await RegisteredSolutionService.DeleteAsync(CurrentSolutionId);
            Reset();
            await OnDeleted.InvokeAsync();
        }
        catch (InvalidOperationException ex)
        {
            SubmissionError = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task CloseAsync()
    {
        Reset();
        await OnClose.InvokeAsync();
    }

    private void LoadFromSolution(RegisteredSolution solution)
    {
        CurrentSolutionId = solution.Id;
        OriginalDisplayName = solution.DisplayName;
        OriginalSolutionPath = solution.SolutionPath;
        Model.DisplayName = solution.DisplayName;
        Model.SolutionPath = solution.SolutionPath;
    }

    private void Reset()
    {
        CurrentSolutionId = Guid.Empty;
        OriginalDisplayName = string.Empty;
        OriginalSolutionPath = string.Empty;
        Model.DisplayName = string.Empty;
        Model.SolutionPath = string.Empty;
        SubmissionError = null;
        IsConfirmingDelete = false;
        ValidationMessageStore?.Clear();
        EditContext.NotifyValidationStateChanged();
    }

    private void HandleFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        SubmissionError = null;

        if (e.FieldIdentifier.FieldName == nameof(EditSolutionModel.SolutionPath))
        {
            ValidationMessageStore?.Clear(e.FieldIdentifier);
            EditContext.NotifyValidationStateChanged();
        }
    }

    public void Dispose()
    {
        EditContext.OnFieldChanged -= HandleFieldChanged;
    }

    public sealed class EditSolutionModel
    {
        [Required(ErrorMessage = "Display name is required.")]
        [StringLength(200, ErrorMessage = "Display name must be 200 characters or fewer.")]
        public string DisplayName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Solution path is required.")]
        [StringLength(2048, ErrorMessage = "Solution path must be 2048 characters or fewer.")]
        public string SolutionPath { get; set; } = string.Empty;
    }
}
