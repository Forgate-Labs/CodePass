@using System.Text.Json
@using CodePass.Web.Services.Rules

<div class="d-flex flex-column gap-2" data-testid="@ContainerTestId">
    <label class="form-label fw-semibold mb-0" for="@FieldId">@Definition.Label</label>
    <p class="form-text mt-0 mb-1">@Definition.Description</p>

    @if (IsBooleanField)
    {
        <div class="form-check">
            <input id="@FieldId"
                   class="form-check-input"
                   type="checkbox"
                   checked="@BoolValue"
                   @onchange="HandleBoolChangedAsync"
                   data-testid="@CheckboxTestId" />
            <label class="form-check-label" for="@FieldId">Enabled</label>
        </div>
    }
    else if (IsMultiSelectField)
    {
        <select id="@FieldId"
                class="form-select"
                multiple
                size="@MultiSelectSize"
                @onchange="HandleMultiSelectChangedAsync"
                data-testid="@MultiSelectTestId">
            @foreach (var option in Definition.AllowedValues!)
            {
                <option value="@option" selected="@SelectedValues.Contains(option, StringComparer.Ordinal)">@option</option>
            }
        </select>
        <div class="form-text">Select one or more values. Use Ctrl/Cmd+click to choose multiple options.</div>
    }
    else if (IsListField)
    {
        <textarea id="@FieldId"
                  class="form-control"
                  rows="4"
                  value="@ListValue"
                  @onchange="HandleListChangedAsync"
                  data-testid="@StringListTestId"></textarea>
        <div class="form-text">Enter one value per line.</div>
    }
    else if (IsSelectField)
    {
        <select id="@FieldId"
                class="form-select"
                value="@StringValue"
                @onchange="HandleStringChangedAsync"
                data-testid="@SelectTestId">
            @foreach (var option in Definition.AllowedValues!)
            {
                <option value="@option">@option</option>
            }
        </select>
    }
    else if (IsNumberField)
    {
        <input id="@FieldId"
               class="form-control"
               type="number"
               value="@StringValue"
               @onchange="HandleNumberChangedAsync"
               data-testid="@NumberTestId" />
    }
    else if (UseTextArea)
    {
        <textarea id="@FieldId"
                  class="form-control"
                  rows="3"
                  value="@StringValue"
                  @onchange="HandleStringChangedAsync"
                  data-testid="@TextAreaTestId"></textarea>
    }
    else
    {
        <input id="@FieldId"
               class="form-control"
               value="@StringValue"
               @onchange="HandleStringChangedAsync"
               data-testid="@TextTestId" />
    }
</div>

@code {
    private string StringValue { get; set; } = string.Empty;
    private bool BoolValue { get; set; }
    private string ListValue { get; set; } = string.Empty;
    private HashSet<string> SelectedValues { get; } = new(StringComparer.Ordinal);

    [Parameter, EditorRequired]
    public RuleCatalogFieldDefinition Definition { get; set; } = default!;

    [Parameter]
    public JsonElement? Value { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<JsonElement?> ValueChanged { get; set; }

    private string FieldId => $"field-{Definition.Name}";
    private string ContainerTestId => $"schema-field-{Definition.Name}";
    private string CheckboxTestId => $"checkbox-field-{Definition.Name}";
    private string StringListTestId => $"string-list-field-{Definition.Name}";
    private string MultiSelectTestId => $"multi-select-field-{Definition.Name}";
    private string SelectTestId => $"select-field-{Definition.Name}";
    private string TextAreaTestId => $"textarea-field-{Definition.Name}";
    private string TextTestId => $"text-field-{Definition.Name}";
    private string NumberTestId => $"number-field-{Definition.Name}";
    private bool IsBooleanField => Definition.JsonType == "boolean";
    private bool IsListField => Definition.JsonType == "array";
    private bool IsMultiSelectField => Definition.JsonType == "array" && Definition.AllowedValues is { Count: > 0 };
    private bool IsNumberField => Definition.JsonType == "number";
    private bool IsSelectField => Definition.JsonType == "string" && Definition.AllowedValues is { Count: > 0 };
    private int MultiSelectSize => Math.Min(Math.Max(Definition.AllowedValues?.Count ?? 2, 2), 8);
    private bool UseTextArea => Definition.JsonType == "string" && Definition.AllowedValues is null && Definition.Name.Contains("regex", StringComparison.OrdinalIgnoreCase);

    protected override void OnParametersSet()
    {
        if (IsBooleanField)
        {
            BoolValue = Value is { ValueKind: JsonValueKind.True } || (Value is { ValueKind: JsonValueKind.False } ? Value.Value.GetBoolean() : false);
            return;
        }

        if (IsListField)
        {
            var values = Value is { ValueKind: JsonValueKind.Array }
                ? Value.Value.EnumerateArray().Select(item => item.GetString()).Where(item => !string.IsNullOrWhiteSpace(item)).ToArray()
                : [];

            ListValue = string.Join(Environment.NewLine, values);
            SelectedValues.Clear();
            foreach (var item in values)
            {
                SelectedValues.Add(item!);
            }

            return;
        }

        StringValue = Value switch
        {
            { ValueKind: JsonValueKind.String } => Value.Value.GetString() ?? string.Empty,
            { ValueKind: JsonValueKind.Number } => Value.Value.GetRawText(),
            _ => string.Empty
        };
    }

    private Task HandleStringChangedAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? string.Empty;
        StringValue = value;
        return ValueChanged.InvokeAsync(JsonSerializer.SerializeToElement(value));
    }

    private Task HandleBoolChangedAsync(ChangeEventArgs args)
    {
        BoolValue = args.Value is bool value && value;
        return ValueChanged.InvokeAsync(JsonSerializer.SerializeToElement(BoolValue));
    }

    private Task HandleNumberChangedAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? string.Empty;
        StringValue = value;
        return int.TryParse(value, out var intValue)
            ? ValueChanged.InvokeAsync(JsonSerializer.SerializeToElement(intValue))
            : ValueChanged.InvokeAsync(null);
    }

    private Task HandleListChangedAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? string.Empty;
        ListValue = value;
        var items = value.Split(["\r\n", "\n"], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return ValueChanged.InvokeAsync(JsonSerializer.SerializeToElement(items));
    }

    private Task HandleMultiSelectChangedAsync(ChangeEventArgs args)
    {
        var values = ExtractSelectedValues(args.Value);
        SelectedValues.Clear();
        foreach (var value in values)
        {
            SelectedValues.Add(value);
        }

        return ValueChanged.InvokeAsync(JsonSerializer.SerializeToElement(values));
    }

    private static string[] ExtractSelectedValues(object? value)
    {
        return value switch
        {
            null => [],
            string stringValue when string.IsNullOrWhiteSpace(stringValue) => [],
            string stringValue => [stringValue],
            string[] stringValues => CleanValues(stringValues),
            IEnumerable<string> stringValues => CleanValues(stringValues),
            IEnumerable<object> objectValues => CleanValues(objectValues.Select(item => item.ToString())),
            _ => []
        };
    }

    private static string[] CleanValues(IEnumerable<string?> values)
        => values.Where(item => !string.IsNullOrWhiteSpace(item)).Select(item => item!).ToArray();
}
