@page "/analysis/rules"
@page "/solutions/{RegisteredSolutionId:guid}/analysis/rules"
@using CodePass.Web.Components.RuleAnalysis
@using CodePass.Web.Components.Rules
@using CodePass.Web.Data.Entities
@using CodePass.Web.Services.RuleAnalysis
@using CodePass.Web.Services.Rules
@using CodePass.Web.Services.Solutions
@inject IRegisteredSolutionService RegisteredSolutionService
@inject IRuleAnalysisRunService RuleAnalysisRunService
@inject IRuleAnalysisResultService RuleAnalysisResultService
@inject IRuleDefinitionService RuleDefinitionService

<PageTitle>Rule Analysis</PageTitle>

<div class="container py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="mb-1">Rule Analysis</h1>
            <p class="text-body-secondary mb-0">Enable authored rules and review manual analysis results for the selected solution workspace.</p>
        </div>

        <div class="d-flex flex-wrap gap-2 align-self-start">
            <button class="btn btn-outline-primary"
                    type="button"
                    @onclick="OpenCreateRuleEditorAsync"
                    data-testid="create-analysis-rule-button">
                New rule
            </button>
            <button class="btn btn-primary"
                    type="button"
                    disabled="@(SelectedSolution is null || IsRunInProgress)"
                    @onclick="StartRuleAnalysisAsync"
                    data-testid="run-rule-analysis-button">
                @(IsRunInProgress ? "Running analysis..." : "Run rule analysis")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="alert alert-danger" role="alert" data-testid="rule-analysis-load-error">@LoadError</div>
    }

    @if (!string.IsNullOrWhiteSpace(RunError))
    {
        <div class="alert alert-danger" role="alert" data-testid="rule-analysis-run-error">@RunError</div>
    }

    @if (!string.IsNullOrWhiteSpace(RuleEditorError))
    {
        <div class="alert alert-danger" role="alert" data-testid="rule-editor-open-error">@RuleEditorError</div>
    }

    @if (IsRunInProgress && CurrentProgress is not null)
    {
        var percentComplete = CurrentProgress.PercentComplete.GetValueOrDefault();
        <div class="card shadow-sm border-primary mb-4" data-testid="rule-analysis-progress" aria-live="polite">
            <div class="card-body">
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
                    <div>
                        <p class="text-uppercase text-primary fw-semibold small mb-1" data-testid="rule-analysis-progress-stage">@FormatProgressStage(CurrentProgress.Stage)</p>
                        <h2 class="h5 mb-1" data-testid="rule-analysis-progress-message">@CurrentProgress.Message</h2>
                        @if (!string.IsNullOrWhiteSpace(CurrentProgress.Detail))
                        {
                            <p class="text-body-secondary small mb-0" data-testid="rule-analysis-progress-detail">@CurrentProgress.Detail</p>
                        }
                    </div>
                    @if (CurrentProgress.Current is not null && CurrentProgress.Total is not null)
                    {
                        <span class="badge text-bg-light" data-testid="rule-analysis-progress-count">@CurrentProgress.Current / @CurrentProgress.Total</span>
                    }
                </div>

                @if (CurrentProgress.PercentComplete is not null)
                {
                    <div class="progress" role="progressbar" aria-label="Rule analysis progress" aria-valuenow="@percentComplete" aria-valuemin="0" aria-valuemax="100" data-testid="rule-analysis-progress-bar">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: @percentComplete%">@percentComplete%</div>
                    </div>
                }
            </div>
        </div>
    }

    @if (IsLoadingSolutions)
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <p class="mb-0 text-body-secondary">Loading registered solutions...</p>
            </div>
        </div>
    }
    else if (Solutions.Count == 0)
    {
        <div class="card shadow-sm border-0" data-testid="rule-analysis-empty-state">
            <div class="card-body p-4 text-center">
                <h2 class="h4 mb-2">No registered solutions yet</h2>
                <p class="text-body-secondary mb-0">Register a local <code>.sln</code> file before running rule analysis.</p>
            </div>
        </div>
    }
    else
    {
        @if (Solutions.Count > 1)
        {
            <div class="card shadow-sm border-0 mb-4" data-testid="rule-analysis-solution-selector">
                <div class="card-body">
                    <p class="text-body-secondary small text-uppercase fw-semibold mb-2">Solution workspace</p>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var solution in Solutions)
                        {
                            <button type="button"
                                    class="btn btn-sm @(SelectedSolution?.Id == solution.Id ? "btn-primary" : "btn-outline-secondary")"
                                    data-testid="select-solution-button"
                                    @onclick="() => SelectSolutionAsync(solution)">
                                @solution.DisplayName
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        @if (SelectedSolution is null)
        {
            <div class="alert alert-warning" role="alert" data-testid="no-valid-solution-message">
                No selected valid solution is available. Choose a solution workspace before reviewing authored-rule assignments. <a href="/solutions" class="alert-link">Choose solution</a>.
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-12 col-xxl-5">
                    <SolutionRuleSelectionPanel @key="RuleSelectionRefreshKey"
                                                RegisteredSolutionId="SelectedSolution.Id"
                                                SolutionName="@SelectedSolution.DisplayName"
                                                OnCreateRule="OpenCreateRuleEditorAsync"
                                                OnEditRule="OpenEditRuleEditorAsync"
                                                OnDeleteRule="RequestDeleteRuleAsync" />
                </div>
                <div class="col-12 col-xxl-7">
                    @if (IsLoadingLatestRun)
                    {
                        <div class="card shadow-sm border-0" data-testid="rule-analysis-results-loading">
                            <div class="card-body">
                                <p class="mb-0 text-body-secondary">Loading latest rule-analysis results...</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <RuleAnalysisResults Run="LatestRun" />
                    }
                </div>
            </div>
        }
    }
</div>

<RuleDefinitionEditor IsOpen="IsRuleEditorOpen"
                      Rule="RuleBeingEdited"
                      OnClose="CloseRuleEditorAsync"
                      OnSaved="HandleRuleSavedAsync" />

@if (IsDeleteConfirmationOpen && RulePendingDeletion is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="delete-rule-confirmation-title">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">
                <div class="modal-header">
                    <h2 class="modal-title h4 mb-0" id="delete-rule-confirmation-title">Delete rule?</h2>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CancelDeleteRuleAsync" disabled="@IsDeletingRule"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">Are you sure you want to delete <strong>@RulePendingDeletion.Title</strong>?</p>
                    <p class="text-body-secondary mb-0">This will permanently remove rule <strong>@RulePendingDeletion.RuleCode</strong> and its solution assignments. This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" @onclick="CancelDeleteRuleAsync" disabled="@IsDeletingRule" data-testid="cancel-delete-rule-button">Cancel</button>
                    <button class="btn btn-danger" type="button" @onclick="ConfirmDeleteRuleAsync" disabled="@IsDeletingRule" data-testid="confirm-delete-rule-button">@(IsDeletingRule ? "Deleting..." : "Delete rule")</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@code {
    private bool IsLoadingSolutions { get; set; } = true;
    private bool IsLoadingLatestRun { get; set; }
    private bool IsRunInProgress { get; set; }
    private RuleAnalysisProgressDto? CurrentProgress { get; set; }
    private string? LoadError { get; set; }
    private string? RunError { get; set; }
    private string? RuleEditorError { get; set; }
    private bool IsRuleEditorOpen { get; set; }
    private bool IsDeleteConfirmationOpen { get; set; }
    private bool IsDeletingRule { get; set; }
    private int RuleSelectionRefreshKey { get; set; }
    private AuthoredRuleDefinitionDto? RuleBeingEdited { get; set; }
    private SolutionRuleSelectionDto? RulePendingDeletion { get; set; }
    private RegisteredSolution? SelectedSolution { get; set; }
    private RuleAnalysisRunDto? LatestRun { get; set; }
    private IReadOnlyList<RegisteredSolution> Solutions { get; set; } = Array.Empty<RegisteredSolution>();

    [Parameter]
    public Guid? RegisteredSolutionId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadSolutionsAsync();
    }

    private async Task LoadSolutionsAsync()
    {
        try
        {
            IsLoadingSolutions = true;
            LoadError = null;
            Solutions = await RegisteredSolutionService.GetAllAsync();
            SelectedSolution = RegisteredSolutionId is Guid routeSolutionId
                ? Solutions.SingleOrDefault(solution => solution.Id == routeSolutionId)
                : Solutions.FirstOrDefault(solution => solution.Status == RegisteredSolutionStatus.Valid);
        }
        catch (Exception ex)
        {
            LoadError = $"Unable to load registered solutions: {ex.Message}";
            Solutions = Array.Empty<RegisteredSolution>();
            SelectedSolution = null;
            LatestRun = null;
        }
        finally
        {
            IsLoadingSolutions = false;
        }

        if (SelectedSolution is not null)
        {
            await LoadLatestRunAsync(SelectedSolution.Id);
        }
    }

    private async Task SelectSolutionAsync(RegisteredSolution solution)
    {
        SelectedSolution = solution;
        await LoadLatestRunAsync(solution.Id);
    }

    private async Task LoadLatestRunAsync(Guid solutionId)
    {
        try
        {
            IsLoadingLatestRun = true;
            RunError = null;
            LatestRun = await RuleAnalysisResultService.GetLatestRunForSolutionAsync(solutionId);
        }
        catch (Exception ex)
        {
            LatestRun = null;
            RunError = $"Unable to load latest rule-analysis results: {ex.Message}";
        }
        finally
        {
            IsLoadingLatestRun = false;
        }
    }

    private async Task StartRuleAnalysisAsync()
    {
        if (SelectedSolution is null)
        {
            return;
        }

        try
        {
            IsRunInProgress = true;
            RunError = null;
            CurrentProgress = new RuleAnalysisProgressDto(
                RuleAnalysisProgressStage.Preparing,
                "Preparing rule analysis...",
                PercentComplete: 0);
            var progress = new Progress<RuleAnalysisProgressDto>(progressUpdate =>
            {
                CurrentProgress = progressUpdate;
                _ = InvokeAsync(StateHasChanged);
            });
            LatestRun = await RuleAnalysisRunService.StartRunAsync(SelectedSolution.Id, progress: progress);
        }
        catch (Exception ex)
        {
            RunError = $"Unable to run rule analysis: {ex.Message}";
        }
        finally
        {
            IsRunInProgress = false;
        }
    }

    private Task OpenCreateRuleEditorAsync()
    {
        RuleEditorError = null;
        RuleBeingEdited = null;
        IsRuleEditorOpen = true;
        return Task.CompletedTask;
    }

    private async Task OpenEditRuleEditorAsync(Guid ruleId)
    {
        try
        {
            RuleEditorError = null;
            var rule = await RuleDefinitionService.GetByIdAsync(ruleId);
            if (rule is null)
            {
                RuleEditorError = "Unable to open rule editor: the selected rule no longer exists.";
                return;
            }

            RuleBeingEdited = rule;
            IsRuleEditorOpen = true;
        }
        catch (Exception ex)
        {
            RuleBeingEdited = null;
            IsRuleEditorOpen = false;
            RuleEditorError = $"Unable to open rule editor: {ex.Message}";
        }
    }

    private Task CloseRuleEditorAsync()
    {
        RuleBeingEdited = null;
        IsRuleEditorOpen = false;
        return Task.CompletedTask;
    }

    private Task HandleRuleSavedAsync()
    {
        RuleBeingEdited = null;
        IsRuleEditorOpen = false;
        RuleSelectionRefreshKey++;
        return Task.CompletedTask;
    }

    private Task RequestDeleteRuleAsync(SolutionRuleSelectionDto selection)
    {
        RuleEditorError = null;
        RulePendingDeletion = selection;
        IsDeleteConfirmationOpen = true;
        return Task.CompletedTask;
    }

    private Task CancelDeleteRuleAsync()
    {
        if (IsDeletingRule)
        {
            return Task.CompletedTask;
        }

        RulePendingDeletion = null;
        IsDeleteConfirmationOpen = false;
        return Task.CompletedTask;
    }

    private async Task ConfirmDeleteRuleAsync()
    {
        if (RulePendingDeletion is null)
        {
            return;
        }

        try
        {
            IsDeletingRule = true;
            RuleEditorError = null;
            await RuleDefinitionService.DeleteAsync(RulePendingDeletion.RuleId);

            if (RuleBeingEdited?.Id == RulePendingDeletion.RuleId)
            {
                RuleBeingEdited = null;
                IsRuleEditorOpen = false;
            }

            RulePendingDeletion = null;
            IsDeleteConfirmationOpen = false;
            RuleSelectionRefreshKey++;
        }
        catch (Exception ex)
        {
            RuleEditorError = $"Unable to delete rule: {ex.Message}";
        }
        finally
        {
            IsDeletingRule = false;
        }
    }

    private static string FormatProgressStage(RuleAnalysisProgressStage stage)
        => stage switch
        {
            RuleAnalysisProgressStage.Preparing => "Preparing",
            RuleAnalysisProgressStage.LoadingRules => "Loading rules",
            RuleAnalysisProgressStage.CreatingRun => "Creating run",
            RuleAnalysisProgressStage.LoadingSolution => "Loading solution",
            RuleAnalysisProgressStage.AnalyzingProjects => "Analyzing projects",
            RuleAnalysisProgressStage.SavingResults => "Saving results",
            RuleAnalysisProgressStage.Completed => "Completed",
            RuleAnalysisProgressStage.Failed => "Failed",
            _ => stage.ToString()
        };

    private static string FormatStatus(RegisteredSolutionStatus status)
        => status switch
        {
            RegisteredSolutionStatus.Valid => "Valid",
            RegisteredSolutionStatus.FileNotFound => "File not found",
            RegisteredSolutionStatus.PathInaccessible => "Path inaccessible",
            RegisteredSolutionStatus.Invalid => "Invalid",
            _ => status.ToString()
        };

    private static string GetSolutionStatusBadgeClass(RegisteredSolutionStatus status)
        => status switch
        {
            RegisteredSolutionStatus.Valid => "text-bg-success",
            RegisteredSolutionStatus.FileNotFound => "text-bg-warning",
            RegisteredSolutionStatus.PathInaccessible => "text-bg-danger",
            RegisteredSolutionStatus.Invalid => "text-bg-secondary",
            _ => "text-bg-secondary"
        };
}
