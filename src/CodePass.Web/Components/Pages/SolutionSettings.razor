@page "/solutions/{RegisteredSolutionId:guid}/settings"
@using System.ComponentModel.DataAnnotations
@using CodePass.Web.Data.Entities
@using CodePass.Web.Services.Dashboard
@using CodePass.Web.Services.Solutions
@inject IRegisteredSolutionService RegisteredSolutionService
@inject IQualityScoreSettingsService QualityScoreSettingsService
@inject NavigationManager NavigationManager

<PageTitle>Solution Settings</PageTitle>

<div class="container py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="mb-1">Solution Settings</h1>
            <p class="text-body-secondary mb-0">Configure score behavior for the selected solution workspace.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="alert alert-danger" role="alert" data-testid="solution-settings-load-error">@LoadError</div>
    }

    @if (!string.IsNullOrWhiteSpace(SaveMessage))
    {
        <div class="alert alert-success" role="status" data-testid="solution-settings-save-message">@SaveMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(SaveError))
    {
        <div class="alert alert-danger" role="alert" data-testid="solution-settings-save-error">@SaveError</div>
    }

    @if (IsLoading)
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <p class="mb-0 text-body-secondary">Loading solution settings...</p>
            </div>
        </div>
    }
    else if (SelectedSolution is null)
    {
        <div class="alert alert-warning" role="alert" data-testid="solution-settings-not-found">
            Solution not found. <a href="/solutions" class="alert-link">Choose solution</a>.
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-7">
                <section class="card shadow-sm border-0" aria-labelledby="score-settings-heading" data-testid="solution-score-settings">
                    <div class="card-body">
                        <h2 class="h4 mb-1" id="score-settings-heading">Score threshold</h2>
                        <p class="text-body-secondary mb-4">
                            Define the minimum final quality score required for <strong>@SelectedSolution.DisplayName</strong> to be considered succeeded.
                        </p>

                        <EditForm Model="FormModel" OnValidSubmit="SaveAsync">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label" for="pass-threshold-input">Succeeded from score</label>
                                <InputNumber id="pass-threshold-input"
                                             class="form-control"
                                             min="0"
                                             max="100"
                                             step="0.1"
                                             @bind-Value="FormModel.PassThreshold"
                                             data-testid="pass-threshold-input" />
                                <ValidationMessage For="() => FormModel.PassThreshold" />
                                <div class="form-text">
                                    Scores below this value are considered fail. Default is 80.
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                <button type="submit" class="btn btn-primary" disabled="@IsSaving" data-testid="save-solution-settings-button">
                                    @(IsSaving ? "Saving..." : "Save settings")
                                </button>
                                <a class="btn btn-outline-secondary" href="@DashboardHref" data-testid="back-to-score-link">Back to score</a>
                            </div>
                        </EditForm>
                    </div>
                </section>
            </div>

            <div class="col-12 col-lg-5">
                <section class="card shadow-sm border-0" data-testid="score-settings-preview">
                    <div class="card-body">
                        <h2 class="h5 mb-3">How it works</h2>
                        <dl class="row small mb-0">
                            <dt class="col-sm-6 text-body-secondary">Succeeded</dt>
                            <dd class="col-sm-6 mb-2">Score ≥ @FormModel.PassThreshold.ToString("0.#")</dd>
                            <dt class="col-sm-6 text-body-secondary">Fail</dt>
                            <dd class="col-sm-6 mb-0">Score &lt; @FormModel.PassThreshold.ToString("0.#")</dd>
                        </dl>
                    </div>
                </section>
            </div>
        </div>
    }
</div>

@code {
    private bool IsLoading { get; set; } = true;
    private bool IsSaving { get; set; }
    private string? LoadError { get; set; }
    private string? SaveError { get; set; }
    private string? SaveMessage { get; set; }
    private RegisteredSolution? SelectedSolution { get; set; }
    private SettingsFormModel FormModel { get; } = new();

    [Parameter]
    public Guid RegisteredSolutionId { get; set; }

    private string DashboardHref => $"/solutions/{RegisteredSolutionId}/dashboard";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            IsLoading = true;
            LoadError = null;
            var solutions = await RegisteredSolutionService.GetAllAsync();
            SelectedSolution = solutions.SingleOrDefault(solution => solution.Id == RegisteredSolutionId);

            if (SelectedSolution is not null)
            {
                var settings = await QualityScoreSettingsService.GetSettingsAsync(RegisteredSolutionId);
                FormModel.PassThreshold = settings.PassThreshold;
            }
        }
        catch (Exception ex)
        {
            LoadError = $"Unable to load solution settings: {ex.Message}";
            SelectedSolution = null;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            IsSaving = true;
            SaveError = null;
            SaveMessage = null;
            var settings = await QualityScoreSettingsService.UpdateSettingsAsync(
                RegisteredSolutionId,
                new UpdateQualityScoreSettingsRequest(FormModel.PassThreshold));
            FormModel.PassThreshold = settings.PassThreshold;
            SaveMessage = "Solution settings saved.";
        }
        catch (Exception ex)
        {
            SaveError = $"Unable to save solution settings: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private sealed class SettingsFormModel
    {
        [Range(0, 100, ErrorMessage = "Pass threshold must be between 0 and 100.")]
        public double PassThreshold { get; set; } = 80;
    }
}
