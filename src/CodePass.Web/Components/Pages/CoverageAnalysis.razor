@page "/analysis/coverage"
@page "/solutions/{RegisteredSolutionId:guid}/analysis/coverage"
@using CodePass.Web.Components.CoverageAnalysis
@using CodePass.Web.Data.Entities
@using CodePass.Web.Services.CoverageAnalysis
@using CodePass.Web.Services.Solutions
@inject IRegisteredSolutionService RegisteredSolutionService
@inject ICoverageAnalysisRunService CoverageAnalysisRunService
@inject ICoverageAnalysisResultService CoverageAnalysisResultService

<PageTitle>Coverage Analysis</PageTitle>

<div class="container py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="mb-1">Coverage Analysis</h1>
            <p class="text-body-secondary mb-0">Run coverage analysis manually and review the latest normalized coverage results for the selected solution workspace.</p>
        </div>

        <button class="btn btn-primary align-self-start"
                type="button"
                disabled="@(SelectedSolution is null || IsRunInProgress)"
                @onclick="StartCoverageAnalysisAsync"
                data-testid="run-coverage-analysis-button">
            @(IsRunInProgress ? "Running coverage..." : "Run coverage analysis")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="alert alert-danger" role="alert" data-testid="coverage-analysis-load-error">@LoadError</div>
    }

    @if (!string.IsNullOrWhiteSpace(RunError))
    {
        <div class="alert alert-danger" role="alert" data-testid="coverage-analysis-run-error">@RunError</div>
    }

    @if (IsRunInProgress && CurrentProgress is not null)
    {
        var percentComplete = CurrentProgress.PercentComplete.GetValueOrDefault();
        <div class="card shadow-sm border-primary mb-4" data-testid="coverage-analysis-progress" aria-live="polite">
            <div class="card-body">
                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
                    <div>
                        <p class="text-uppercase text-primary fw-semibold small mb-1" data-testid="coverage-analysis-progress-stage">@FormatProgressStage(CurrentProgress.Stage)</p>
                        <h2 class="h5 mb-1" data-testid="coverage-analysis-progress-message">@CurrentProgress.Message</h2>
                        @if (!string.IsNullOrWhiteSpace(CurrentProgress.Detail))
                        {
                            <p class="text-body-secondary small mb-0" data-testid="coverage-analysis-progress-detail">@CurrentProgress.Detail</p>
                        }
                    </div>
                    @if (CurrentProgress.Current is not null && CurrentProgress.Total is not null)
                    {
                        <span class="badge text-bg-light" data-testid="coverage-analysis-progress-count">@CurrentProgress.Current / @CurrentProgress.Total</span>
                    }
                </div>

                @if (CurrentProgress.PercentComplete is not null)
                {
                    <div class="progress" role="progressbar" aria-label="Coverage analysis progress" aria-valuenow="@percentComplete" aria-valuemin="0" aria-valuemax="100" data-testid="coverage-analysis-progress-bar">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: @percentComplete%">@percentComplete%</div>
                    </div>
                }

                @if (ProgressHistory.Count > 0)
                {
                    <div class="mt-3 border-top pt-3" data-testid="coverage-analysis-progress-history">
                        <p class="text-uppercase text-body-secondary fw-semibold small mb-2">Execution details</p>
                        <ol class="list-unstyled d-flex flex-column gap-2 mb-0 small">
                            @foreach (var progressItem in ProgressHistory)
                            {
                                <li class="d-flex flex-column flex-md-row gap-1 gap-md-2" data-testid="coverage-analysis-progress-history-item">
                                    <span class="text-body-secondary flex-shrink-0">@progressItem.UpdatedAtUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                                    <span class="fw-semibold flex-shrink-0">@FormatProgressStage(progressItem.Stage)</span>
                                    <span>@progressItem.Message</span>
                                    @if (!string.IsNullOrWhiteSpace(progressItem.Detail))
                                    {
                                        <code class="text-break">@progressItem.Detail</code>
                                    }
                                </li>
                            }
                        </ol>
                    </div>
                }
            </div>
        </div>
    }

    @if (IsLoadingSolutions)
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <p class="mb-0 text-body-secondary">Loading registered solutions...</p>
            </div>
        </div>
    }
    else if (Solutions.Count == 0)
    {
        <div class="card shadow-sm border-0" data-testid="coverage-analysis-empty-state">
            <div class="card-body p-4 text-center">
                <h2 class="h4 mb-2">No registered solutions yet</h2>
                <p class="text-body-secondary mb-0">Register a local <code>.sln</code> file before running coverage analysis.</p>
            </div>
        </div>
    }
    else
    {
        @if (Solutions.Count > 1)
        {
            <div class="card shadow-sm border-0 mb-4" data-testid="coverage-analysis-solution-selector">
                <div class="card-body">
                    <p class="text-body-secondary small text-uppercase fw-semibold mb-2">Solution workspace</p>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var solution in Solutions)
                        {
                            <button type="button"
                                    class="btn btn-sm @(SelectedSolution?.Id == solution.Id ? "btn-primary" : "btn-outline-secondary")"
                                    data-testid="select-solution-button"
                                    @onclick="() => SelectSolutionAsync(solution)">
                                @solution.DisplayName
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        @if (SelectedSolution is null)
        {
            <div class="alert alert-warning" role="alert" data-testid="coverage-no-valid-solution-message">
                No selected valid solution is available. Choose a solution workspace before reviewing coverage evidence. <a href="/solutions" class="alert-link">Choose solution</a>.
            </div>
        }
        else
        {
            @if (SelectedSolution.Status != RegisteredSolutionStatus.Valid)
            {
                <div class="alert alert-warning" role="alert" data-testid="coverage-invalid-solution-message">
                    The selected solution is currently @FormatStatus(SelectedSolution.Status). A coverage run can record the failure details, but dotnet coverage execution requires a valid solution.
                </div>
            }

            @if (IsLoadingLatestRun)
            {
                <div class="card shadow-sm border-0" data-testid="coverage-analysis-results-loading">
                    <div class="card-body">
                        <p class="mb-0 text-body-secondary">Loading latest coverage-analysis results...</p>
                    </div>
                </div>
            }
            else
            {
                <CoverageAnalysisResults Run="LatestRun" />
            }
        }
    }
</div>

@code {
    private bool IsLoadingSolutions { get; set; } = true;
    private bool IsLoadingLatestRun { get; set; }
    private bool IsRunInProgress { get; set; }
    private CoverageAnalysisProgressDto? CurrentProgress { get; set; }
    private List<CoverageAnalysisProgressDto> ProgressHistory { get; } = [];
    private string? LoadError { get; set; }
    private string? RunError { get; set; }
    private RegisteredSolution? SelectedSolution { get; set; }
    private CoverageAnalysisRunDto? LatestRun { get; set; }
    private IReadOnlyList<RegisteredSolution> Solutions { get; set; } = Array.Empty<RegisteredSolution>();

    [Parameter]
    public Guid? RegisteredSolutionId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadSolutionsAsync();
    }

    private async Task LoadSolutionsAsync()
    {
        try
        {
            IsLoadingSolutions = true;
            LoadError = null;
            Solutions = await RegisteredSolutionService.GetAllAsync();
            SelectedSolution = RegisteredSolutionId is Guid routeSolutionId
                ? Solutions.SingleOrDefault(solution => solution.Id == routeSolutionId)
                : Solutions.FirstOrDefault(solution => solution.Status == RegisteredSolutionStatus.Valid);
        }
        catch (Exception ex)
        {
            LoadError = $"Unable to load registered solutions: {ex.Message}";
            Solutions = Array.Empty<RegisteredSolution>();
            SelectedSolution = null;
            LatestRun = null;
        }
        finally
        {
            IsLoadingSolutions = false;
        }

        if (SelectedSolution is not null)
        {
            await LoadLatestRunAsync(SelectedSolution.Id);
        }
    }

    private async Task SelectSolutionAsync(RegisteredSolution solution)
    {
        SelectedSolution = solution;
        await LoadLatestRunAsync(solution.Id);
    }

    private async Task LoadLatestRunAsync(Guid solutionId)
    {
        try
        {
            IsLoadingLatestRun = true;
            RunError = null;
            LatestRun = await CoverageAnalysisResultService.GetLatestRunForSolutionAsync(solutionId);
        }
        catch (Exception ex)
        {
            LatestRun = null;
            RunError = $"Unable to load latest coverage-analysis results: {ex.Message}";
        }
        finally
        {
            IsLoadingLatestRun = false;
        }
    }

    private async Task StartCoverageAnalysisAsync()
    {
        if (SelectedSolution is null)
        {
            return;
        }

        try
        {
            IsRunInProgress = true;
            RunError = null;
            CurrentProgress = new CoverageAnalysisProgressDto(
                CoverageAnalysisProgressStage.Preparing,
                "Preparing coverage analysis...",
                PercentComplete: 0);
            ProgressHistory.Clear();
            AddProgressHistory(CurrentProgress);
            var progress = new Progress<CoverageAnalysisProgressDto>(progressUpdate =>
            {
                CurrentProgress = progressUpdate;
                AddProgressHistory(progressUpdate);
                _ = InvokeAsync(StateHasChanged);
            });
            await CoverageAnalysisRunService.StartRunAsync(SelectedSolution.Id, progress: progress);
            await LoadLatestRunAsync(SelectedSolution.Id);
        }
        catch (Exception ex)
        {
            RunError = $"Unable to run coverage analysis: {ex.Message}";
        }
        finally
        {
            IsRunInProgress = false;
        }
    }

    private void AddProgressHistory(CoverageAnalysisProgressDto progressUpdate)
    {
        ProgressHistory.Add(progressUpdate);
        if (ProgressHistory.Count > 12)
        {
            ProgressHistory.RemoveRange(0, ProgressHistory.Count - 12);
        }
    }

    private static string FormatProgressStage(CoverageAnalysisProgressStage stage)
        => stage switch
        {
            CoverageAnalysisProgressStage.Preparing => "Preparing",
            CoverageAnalysisProgressStage.CreatingRun => "Creating run",
            CoverageAnalysisProgressStage.RunningTests => "Running tests",
            CoverageAnalysisProgressStage.CollectingCoverage => "Collecting coverage",
            CoverageAnalysisProgressStage.ParsingCoverage => "Parsing coverage",
            CoverageAnalysisProgressStage.SavingResults => "Saving results",
            CoverageAnalysisProgressStage.Completed => "Completed",
            CoverageAnalysisProgressStage.Failed => "Failed",
            _ => stage.ToString()
        };

    private static string FormatStatus(RegisteredSolutionStatus status)
        => status switch
        {
            RegisteredSolutionStatus.Valid => "Valid",
            RegisteredSolutionStatus.FileNotFound => "File not found",
            RegisteredSolutionStatus.PathInaccessible => "Path inaccessible",
            RegisteredSolutionStatus.Invalid => "Invalid",
            _ => status.ToString()
        };

    private static string GetSolutionStatusBadgeClass(RegisteredSolutionStatus status)
        => status switch
        {
            RegisteredSolutionStatus.Valid => "text-bg-success",
            RegisteredSolutionStatus.FileNotFound => "text-bg-warning",
            RegisteredSolutionStatus.PathInaccessible => "text-bg-danger",
            RegisteredSolutionStatus.Invalid => "text-bg-secondary",
            _ => "text-bg-secondary"
        };

}
