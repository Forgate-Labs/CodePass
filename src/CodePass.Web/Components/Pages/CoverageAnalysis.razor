@page "/analysis/coverage"
@using CodePass.Web.Data.Entities
@using CodePass.Web.Services.CoverageAnalysis
@using CodePass.Web.Services.Solutions
@inject IRegisteredSolutionService RegisteredSolutionService
@inject ICoverageAnalysisRunService CoverageAnalysisRunService
@inject ICoverageAnalysisResultService CoverageAnalysisResultService

<PageTitle>Coverage Analysis</PageTitle>

<div class="container py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="mb-1">Coverage Analysis</h1>
            <p class="text-body-secondary mb-0">Choose a registered solution, run coverage analysis manually, and review the latest normalized coverage results.</p>
        </div>

        <button class="btn btn-primary align-self-start"
                type="button"
                disabled="@(SelectedSolution is null || IsRunInProgress)"
                @onclick="StartCoverageAnalysisAsync"
                data-testid="run-coverage-analysis-button">
            @(IsRunInProgress ? "Running coverage..." : "Run coverage analysis")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="alert alert-danger" role="alert" data-testid="coverage-analysis-load-error">@LoadError</div>
    }

    @if (!string.IsNullOrWhiteSpace(RunError))
    {
        <div class="alert alert-danger" role="alert" data-testid="coverage-analysis-run-error">@RunError</div>
    }

    @if (IsLoadingSolutions)
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <p class="mb-0 text-body-secondary">Loading registered solutions...</p>
            </div>
        </div>
    }
    else if (Solutions.Count == 0)
    {
        <div class="card shadow-sm border-0" data-testid="coverage-analysis-empty-state">
            <div class="card-body p-4 text-center">
                <h2 class="h4 mb-2">No registered solutions yet</h2>
                <p class="text-body-secondary mb-0">Register a local <code>.sln</code> file before running coverage analysis.</p>
            </div>
        </div>
    }
    else
    {
        <section class="mb-4" aria-labelledby="coverage-solution-selection-heading">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div>
                    <h2 class="h4 mb-1" id="coverage-solution-selection-heading">Select a solution</h2>
                    <p class="text-body-secondary mb-0">CodePass defaults to the first valid registered solution when one is available.</p>
                </div>
            </div>

            <div class="row g-3" data-testid="coverage-analysis-solution-list">
                @foreach (var solution in Solutions)
                {
                    var isSelected = SelectedSolution?.Id == solution.Id;
                    <div class="col-12 col-xl-6" data-testid="coverage-analysis-solution-card">
                        <button class="card h-100 w-100 text-start shadow-sm @(isSelected ? "border-primary" : "border-0")"
                                type="button"
                                @onclick="() => SelectSolutionAsync(solution.Id)"
                                aria-pressed="@isSelected.ToString().ToLowerInvariant()"
                                data-testid="select-solution-button">
                            <div class="card-body">
                                <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                                    <div>
                                        <h3 class="h5 mb-1" data-testid="coverage-analysis-solution-name">@solution.DisplayName</h3>
                                        <p class="text-body-secondary small mb-0" data-testid="coverage-analysis-solution-path">@solution.SolutionPath</p>
                                    </div>
                                    <span class="badge @GetSolutionStatusBadgeClass(solution.Status)" data-testid="coverage-analysis-solution-status">@FormatStatus(solution.Status)</span>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(solution.StatusMessage))
                                {
                                    <p class="small text-body-secondary mb-0">@solution.StatusMessage</p>
                                }
                            </div>
                        </button>
                    </div>
                }
            </div>
        </section>

        @if (SelectedSolution is null)
        {
            <div class="alert alert-warning" role="alert" data-testid="coverage-no-valid-solution-message">
                No valid registered solution is available yet. Select a solution above to inspect its latest coverage run or see why a new run cannot complete.
            </div>
        }
        else
        {
            @if (SelectedSolution.Status != RegisteredSolutionStatus.Valid)
            {
                <div class="alert alert-warning" role="alert" data-testid="coverage-invalid-solution-message">
                    The selected solution is currently @FormatStatus(SelectedSolution.Status). A coverage run can record the failure details, but dotnet coverage execution requires a valid solution.
                </div>
            }

            @if (IsLoadingLatestRun)
            {
                <div class="card shadow-sm border-0" data-testid="coverage-analysis-results-loading">
                    <div class="card-body">
                        <p class="mb-0 text-body-secondary">Loading latest coverage-analysis results...</p>
                    </div>
                </div>
            }
            else if (LatestRun is null)
            {
                <div class="card shadow-sm border-0" data-testid="coverage-analysis-no-results">
                    <div class="card-body p-4 text-center">
                        <h2 class="h4 mb-2">No coverage-analysis runs yet</h2>
                        <p class="text-body-secondary mb-0">Run coverage analysis to see normalized project and class coverage here.</p>
                    </div>
                </div>
            }
            else
            {
                <section class="card shadow-sm border-0" aria-labelledby="coverage-analysis-latest-heading" data-testid="coverage-analysis-latest-run">
                    <div class="card-body">
                        <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-between gap-3 mb-3">
                            <div>
                                <h2 class="h4 mb-1" id="coverage-analysis-latest-heading">Latest coverage run</h2>
                                <p class="text-body-secondary mb-0">Normalized results for @SelectedSolution.DisplayName.</p>
                            </div>
                            <span class="badge @GetCoverageStatusBadgeClass(LatestRun.Status)" data-testid="coverage-run-status">@LatestRun.Status</span>
                        </div>

                        <dl class="row small mb-0" data-testid="coverage-run-summary">
                            <dt class="col-sm-4 text-body-secondary">Projects</dt>
                            <dd class="col-sm-8 mb-2">@LatestRun.ProjectCount</dd>

                            <dt class="col-sm-4 text-body-secondary">Classes</dt>
                            <dd class="col-sm-8 mb-2">@LatestRun.ClassCount</dd>

                            <dt class="col-sm-4 text-body-secondary">Line coverage</dt>
                            <dd class="col-sm-8 mb-2">@FormatPercent(LatestRun.LineCoveragePercent)</dd>

                            <dt class="col-sm-4 text-body-secondary">Branch coverage</dt>
                            <dd class="col-sm-8 mb-0">@FormatPercent(LatestRun.BranchCoveragePercent)</dd>
                        </dl>
                    </div>
                </section>
            }
        }
    }
</div>

@code {
    private bool IsLoadingSolutions { get; set; } = true;
    private bool IsLoadingLatestRun { get; set; }
    private bool IsRunInProgress { get; set; }
    private string? LoadError { get; set; }
    private string? RunError { get; set; }
    private RegisteredSolution? SelectedSolution { get; set; }
    private CoverageAnalysisRunDto? LatestRun { get; set; }
    private IReadOnlyList<RegisteredSolution> Solutions { get; set; } = Array.Empty<RegisteredSolution>();

    protected override async Task OnInitializedAsync()
    {
        await LoadSolutionsAsync();
    }

    private async Task LoadSolutionsAsync()
    {
        try
        {
            IsLoadingSolutions = true;
            LoadError = null;
            Solutions = await RegisteredSolutionService.GetAllAsync();
            SelectedSolution = Solutions.FirstOrDefault(solution => solution.Status == RegisteredSolutionStatus.Valid);
        }
        catch (Exception ex)
        {
            LoadError = $"Unable to load registered solutions: {ex.Message}";
            Solutions = Array.Empty<RegisteredSolution>();
            SelectedSolution = null;
            LatestRun = null;
        }
        finally
        {
            IsLoadingSolutions = false;
        }

        if (SelectedSolution is not null)
        {
            await LoadLatestRunAsync(SelectedSolution.Id);
        }
    }

    private async Task SelectSolutionAsync(Guid solutionId)
    {
        SelectedSolution = Solutions.SingleOrDefault(solution => solution.Id == solutionId);
        RunError = null;

        if (SelectedSolution is null)
        {
            LatestRun = null;
            return;
        }

        await LoadLatestRunAsync(SelectedSolution.Id);
    }

    private async Task LoadLatestRunAsync(Guid solutionId)
    {
        try
        {
            IsLoadingLatestRun = true;
            RunError = null;
            LatestRun = await CoverageAnalysisResultService.GetLatestRunForSolutionAsync(solutionId);
        }
        catch (Exception ex)
        {
            LatestRun = null;
            RunError = $"Unable to load latest coverage-analysis results: {ex.Message}";
        }
        finally
        {
            IsLoadingLatestRun = false;
        }
    }

    private async Task StartCoverageAnalysisAsync()
    {
        if (SelectedSolution is null)
        {
            return;
        }

        try
        {
            IsRunInProgress = true;
            RunError = null;
            await CoverageAnalysisRunService.StartRunAsync(SelectedSolution.Id);
            await LoadLatestRunAsync(SelectedSolution.Id);
        }
        catch (Exception ex)
        {
            RunError = $"Unable to run coverage analysis: {ex.Message}";
        }
        finally
        {
            IsRunInProgress = false;
        }
    }

    private static string FormatStatus(RegisteredSolutionStatus status)
        => status switch
        {
            RegisteredSolutionStatus.Valid => "Valid",
            RegisteredSolutionStatus.FileNotFound => "File not found",
            RegisteredSolutionStatus.PathInaccessible => "Path inaccessible",
            RegisteredSolutionStatus.Invalid => "Invalid",
            _ => status.ToString()
        };

    private static string GetSolutionStatusBadgeClass(RegisteredSolutionStatus status)
        => status switch
        {
            RegisteredSolutionStatus.Valid => "text-bg-success",
            RegisteredSolutionStatus.FileNotFound => "text-bg-warning",
            RegisteredSolutionStatus.PathInaccessible => "text-bg-danger",
            RegisteredSolutionStatus.Invalid => "text-bg-secondary",
            _ => "text-bg-secondary"
        };

    private static string GetCoverageStatusBadgeClass(CoverageAnalysisRunStatus status)
        => status switch
        {
            CoverageAnalysisRunStatus.Succeeded => "text-bg-success",
            CoverageAnalysisRunStatus.Failed => "text-bg-danger",
            CoverageAnalysisRunStatus.Running => "text-bg-warning",
            _ => "text-bg-secondary"
        };

    private static string FormatPercent(double value)
        => $"{value:0.0}%";
}
