@using CodePass.Web.Data.Entities
@using CodePass.Web.Services.RuleAnalysis

<section class="card shadow-sm border-0" aria-labelledby="rule-analysis-results-heading" data-testid="rule-analysis-results">
    <div class="card-body">
        <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-between gap-3 mb-3">
            <div>
                <h2 class="h4 mb-1" id="rule-analysis-results-heading">Latest results</h2>
                <p class="text-body-secondary mb-0">Review the most recent manual rule-analysis run for the selected solution.</p>
            </div>

            @if (Run is not null)
            {
                <span class="badge @GetStatusBadgeClass(Run.Status)" data-testid="run-status">@Run.Status</span>
            }
        </div>

        @if (Run is null)
        {
            <div class="border rounded-3 p-4 text-center" data-testid="rule-analysis-no-results">
                <h3 class="h5 mb-2">No rule-analysis runs yet</h3>
                <p class="text-body-secondary mb-0">Run rule analysis to see grouped authored-rule results here.</p>
            </div>
        }
        else
        {
            <dl class="row small mb-3" data-testid="run-summary">
                <dt class="col-sm-4 text-body-secondary">Started</dt>
                <dd class="col-sm-8 mb-2" data-testid="run-started">@FormatDateTime(Run.StartedAtUtc)</dd>

                <dt class="col-sm-4 text-body-secondary">Completed</dt>
                <dd class="col-sm-8 mb-2" data-testid="run-completed">@(Run.CompletedAtUtc is null ? "Not completed" : FormatDateTime(Run.CompletedAtUtc.Value))</dd>

                <dt class="col-sm-4 text-body-secondary">Rules analyzed</dt>
                <dd class="col-sm-8 mb-2" data-testid="run-rule-count">@Run.RuleCount</dd>

                <dt class="col-sm-4 text-body-secondary">Total violations</dt>
                <dd class="col-sm-8 mb-0" data-testid="run-total-violations">@Run.TotalViolations</dd>
            </dl>

            @if (Run.Status == RuleAnalysisRunStatus.Failed && !string.IsNullOrWhiteSpace(Run.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert" data-testid="run-error-message">
                    @Run.ErrorMessage
                </div>
            }
            else if (Run.Status == RuleAnalysisRunStatus.Succeeded && Run.TotalViolations == 0)
            {
                <div class="alert alert-success" role="status" data-testid="zero-violations-success">
                    No violations found for the enabled authored rules.
                </div>
            }

            @if (Run.RuleGroups.Count > 0)
            {
                <div class="d-flex flex-column gap-3" data-testid="rule-result-groups">
                    @foreach (var group in Run.RuleGroups)
                    {
                        <article class="card border" data-testid="rule-result-group">
                            <div class="card-header bg-transparent">
                                <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-between gap-3">
                                    <div>
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                            <span class="text-body-secondary small text-uppercase fw-semibold" data-testid="result-rule-code">@group.RuleCode</span>
                                            <span class="badge @GetSeverityBadgeClass(group.Severity)" data-testid="result-rule-severity">@group.Severity</span>
                                            <span class="badge text-bg-light" data-testid="result-rule-kind">@group.RuleKind</span>
                                        </div>
                                        <h3 class="h5 mb-0" data-testid="result-rule-title">@group.RuleTitle</h3>
                                    </div>

                                    <span class="badge text-bg-secondary" data-testid="result-violation-count">@group.ViolationCount violation@(group.ViolationCount == 1 ? string.Empty : "s")</span>
                                </div>
                            </div>

                            <div class="list-group list-group-flush">
                                @foreach (var violation in group.Violations)
                                {
                                    <div class="list-group-item" data-testid="violation-row">
                                        <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-between gap-3">
                                            <div>
                                                <p class="fw-semibold mb-1" data-testid="violation-message">@violation.Message</p>
                                                <p class="text-body-secondary small mb-0" data-testid="violation-file-path">@violation.FilePath</p>
                                            </div>
                                            <div class="text-lg-end small">
                                                <div>
                                                    <span class="badge @GetSeverityBadgeClass(violation.Severity)" data-testid="violation-severity">@violation.Severity</span>
                                                </div>
                                                <div class="text-body-secondary mt-2" data-testid="violation-start-location">@violation.StartLine:@violation.StartColumn</div>
                                                @if (HasEndLocation(violation))
                                                {
                                                    <div class="text-body-secondary" data-testid="violation-end-location">Ends @violation.EndLine:@violation.EndColumn</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        }
    </div>
</section>

@code {
    [Parameter]
    public RuleAnalysisRunDto? Run { get; set; }

    private static string FormatDateTime(DateTimeOffset dateTime)
        => dateTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static bool HasEndLocation(RuleAnalysisViolationDto violation)
        => violation.EndLine > 0
            && violation.EndColumn > 0
            && (violation.EndLine != violation.StartLine || violation.EndColumn != violation.StartColumn);

    private static string GetStatusBadgeClass(RuleAnalysisRunStatus status)
        => status switch
        {
            RuleAnalysisRunStatus.Succeeded => "text-bg-success",
            RuleAnalysisRunStatus.Failed => "text-bg-danger",
            RuleAnalysisRunStatus.Running => "text-bg-warning",
            _ => "text-bg-secondary"
        };

    private static string GetSeverityBadgeClass(RuleSeverity severity)
        => severity switch
        {
            RuleSeverity.Error => "text-bg-danger",
            RuleSeverity.Warning => "text-bg-warning",
            RuleSeverity.Info => "text-bg-info",
            _ => "text-bg-secondary"
        };
}
